from langchain_community.document_loaders import PyPDFLoader
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_community.embeddings import HuggingFaceEmbeddings
from langchain_community.vectorstores import Chroma

from transformers import AutoTokenizer, AutoModelForSeq2SeqLM, pipeline


model_name = "google/flan-t5-small"

tokenizer = AutoTokenizer.from_pretrained(model_name)
model = AutoModelForSeq2SeqLM.from_pretrained(model_name)

qa_pipeline = pipeline(
    "text2text-generation",
    model=model,
    tokenizer=tokenizer
)


def setup_rag(file_path):
    loader = PyPDFLoader(file_path)
    documents = loader.load()

    splitter = RecursiveCharacterTextSplitter(
        chunk_size=500,
        chunk_overlap=50
    )
    chunks = splitter.split_documents(documents)

    embedding = HuggingFaceEmbeddings(
        model_name="all-MiniLM-L6-v2"
    )

    db = Chroma.from_documents(
        chunks,
        embedding,
        persist_directory="db"
    )

    return db, documents


def retrieve_context(db, documents, query):
    retriever = db.as_retriever(search_kwargs={"k": 5})
    docs = retriever.invoke(query)

    retrieved_chunks = [doc.page_content for doc in docs]
    first_page = documents[0].page_content

    context = first_page + "\n" + "\n".join(retrieved_chunks)

    return context[:1500]


def ask_question(db, documents, query):
    query_lower = query.lower()
    first_page = documents[0].page_content

    if "author" in query_lower:
        lines = first_page.split("\n")
        authors = []

        for line in lines:
            line = line.strip()

            if (
                len(line.split()) <= 4 and
                line and
                line[0].isupper() and
                "@" not in line and
                "Google" not in line and
                "*" in line
            ):
                authors.append(line.replace("*", ""))

        if authors:
            return "\nAnswer:\n" + ", ".join(authors)

    if "title" in query_lower:
        for line in first_page.split("\n"):
            if "attention is all you need" in line.lower():
                return "\nAnswer:\n" + line.strip()

    context = retrieve_context(db, documents, query)

    if not context:
        return "\nAnswer:\nLow confidence. Escalate to human support."

    prompt = f"""
Answer the question using the context below.

Context:
{context}

Question:
{query}

Answer:
"""

    result = qa_pipeline(prompt, max_length=120)

    return "\nAnswer:\n" + result[0]["generated_text"]


if __name__ == "__main__":
    file_path = "data/sample.pdf"

    db, documents = setup_rag(file_path)

    while True:
        query = input("\nAsk a question: ")
        response = ask_question(db, documents, query)
        print(response)